# .env.example — copy to .env and fill in
# NEVER commit .env — see .gitignore

# ============================================================
# Free-tier search APIs (Layer 3 fallbacks)
# ref: MASTER_PLAN_v5.md § 6.4
# ============================================================

# Brave Search API — 2,000 queries/month free
# https://brave.com/search/api/
BRAVE_API_KEY=

# Tavily — 1,000 credits/month free
# https://tavily.com
TAVILY_API_KEY=

# SearXNG runs locally (Docker) — no API key needed
SEARXNG_URL=http://localhost:8888


# ============================================================
# Microsoft Copilot / Azure OpenAI (Section 18)
# Use only if needed for cloud fallback (escalation)
# ============================================================

# Microsoft Graph (for Copilot Chat — student tier)
MS_TENANT_ID=
MS_CLIENT_ID=
MS_CLIENT_SECRET=
MS_USER_PRINCIPAL_NAME=

# Azure OpenAI (paid fallback — optional)
AZURE_OPENAI_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_VERSION=2024-12-01-preview


# ============================================================
# Observability (self-hosted defaults)
# ============================================================

LANGFUSE_HOST=http://localhost:3000
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=

PHOENIX_HOST=http://localhost:6006


# ============================================================
# System
# ============================================================

# Ollama
OLLAMA_HOST=http://localhost:11434

# ChromaDB
CHROMA_PATH=./chroma_db

# Daily budget for paid services (USD)
# 0 = disabled (block all paid calls)
DAILY_BUDGET_USD=0


# ============================================================
# Feature flags
# ============================================================

# Enable uncensored model option (§ 4.2 Option B)
# Use only when standard Qwen3 refuses legitimate engineering queries
ENABLE_UNCENSORED_FALLBACK=false

# Enable cloud escalation (Section 18)
# Default false — must opt-in
ENABLE_CLOUD_FALLBACK=false

# Enable activity tracking outside AI sessions (Section 14.4)
# Requires consent in .tpm_context/logger_consent.json
ENABLE_OUTSIDE_TRACKING=false


# ============================================================
# GitHub backup (Section 20)
# ============================================================

# Set after creating private knowledge repo
KNOWLEDGE_REPO_REMOTE=git@github.com:YOU/tpm-knowledge-private.git
FRAMEWORK_REPO_REMOTE=git@github.com:YOU/tpm-ai-framework.git
