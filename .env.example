# .env.example — copy to .env and fill in
# NEVER commit .env — see .gitignore

# ============================================================
# Free-tier search APIs (Layer 3 — lane assignment per § 6.4.0)
# ref: MASTER_PLAN_v5.md § 6.4
# ============================================================

# SearXNG (workhorse) — self-hosted Docker, no API key, unlimited
SEARXNG_URL=http://localhost:8888

# Tavily (AI-optimized for LLM context) — 1,000 credits/month free
# https://tavily.com
TAVILY_API_KEY=

# Exa.ai (structured output + grounding) — 1,000 requests/month free
# https://dashboard.exa.ai
# OPTIONAL: leave blank if you use the MCP OAuth flow instead:
#   claude mcp add --transport http exa https://mcp.exa.ai/mcp
EXA_API_KEY=

# DuckDuckGo Instant Answer — no API key, unlimited (used via duckduckgo-search package)
# Wikipedia REST — no API key, unlimited (used via wikipedia-api package)
# Jina Reader — no API key, free tier (used via https://r.jina.ai/<url>)
# (no env vars needed for the three above)

# NOTE: Brave Search API was dropped in v5.0 update (May 2026)
# Reason: Brave EOL'd their free tier in Feb 2026


# ============================================================
# Microsoft Copilot / Azure OpenAI (Section 18)
# Use only if needed for cloud fallback (escalation)
# ============================================================

# Microsoft Graph (for Copilot Chat — student tier)
MS_TENANT_ID=
MS_CLIENT_ID=
MS_CLIENT_SECRET=
MS_USER_PRINCIPAL_NAME=

# Azure OpenAI (paid fallback — optional)
AZURE_OPENAI_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_VERSION=2024-12-01-preview


# ============================================================
# Observability (self-hosted defaults)
# ============================================================

LANGFUSE_HOST=http://localhost:3000
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=

PHOENIX_HOST=http://localhost:6006


# ============================================================
# System
# ============================================================

# Ollama
OLLAMA_HOST=http://localhost:11434

# ChromaDB
CHROMA_PATH=./chroma_db

# Daily budget for paid services (USD)
# 0 = disabled (block all paid calls)
DAILY_BUDGET_USD=0


# ============================================================
# Feature flags
# ============================================================

# Enable uncensored model option (§ 4.2 Option B)
# Use only when standard Qwen3 refuses legitimate engineering queries
ENABLE_UNCENSORED_FALLBACK=false

# Enable cloud escalation (Section 18)
# Default false — must opt-in
ENABLE_CLOUD_FALLBACK=false

# Enable activity tracking outside AI sessions (Section 14.4)
# Requires consent in .tpm_context/logger_consent.json
ENABLE_OUTSIDE_TRACKING=false


# ============================================================
# GitHub backup (Section 20)
# ============================================================

# Set after creating private knowledge repo
KNOWLEDGE_REPO_REMOTE=git@github.com:YOU/tpm-knowledge-private.git
FRAMEWORK_REPO_REMOTE=git@github.com:YOU/tpm-ai-framework.git
