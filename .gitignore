# ============================================================
# .gitignore — root (tpm-ai-framework repo)
# อ้างอิง: MASTER_PLAN_v5.md § 20.3
# ============================================================

# ------------------------------------------------------------
# Models (re-downloadable from HuggingFace / Ollama)
# ------------------------------------------------------------
models/
*.gguf
*.bin
*.safetensors
*.onnx

# ------------------------------------------------------------
# Raw proprietary data — NEVER commit
# ------------------------------------------------------------
raw_data/
!raw_data/.gitkeep

# ------------------------------------------------------------
# Knowledge — managed by separate private repo
# (.tpm_context/.git → tpm-knowledge-private repo)
# ------------------------------------------------------------
.tpm_context/

# ------------------------------------------------------------
# Caches
# ------------------------------------------------------------
chroma_db/
__pycache__/
*.pyc
*.pyo
*.pyd
.pytest_cache/
.ruff_cache/
.mypy_cache/
.coverage
htmlcov/
.tox/
.cache/
*.egg-info/
build/
dist/

# ------------------------------------------------------------
# Databases — use SQL dumps in .tpm_context/dumps/ instead
# ------------------------------------------------------------
*.db
*.sqlite
*.sqlite3
*.db-journal

# ------------------------------------------------------------
# Secrets & credentials — NEVER commit
# ------------------------------------------------------------
.env
.env.*
!.env.example
*.key
*.pem
*.p12
*.pfx
credentials.json
secrets.yaml
.secrets.baseline

# ------------------------------------------------------------
# OS
# ------------------------------------------------------------
.DS_Store
Thumbs.db
desktop.ini
ehthumbs.db
$RECYCLE.BIN/

# ------------------------------------------------------------
# IDE / AI tooling
# ------------------------------------------------------------
.vscode/
.idea/
.claude/
.cursor/
.aider*
*.swp
*.swo
*~
.project
.classpath
.settings/

# ------------------------------------------------------------
# Logs (rotated separately)
# ------------------------------------------------------------
logs/
*.log
*.log.*

# ------------------------------------------------------------
# Outputs (regenerable)
# ------------------------------------------------------------
output/
!output/.gitkeep

# ------------------------------------------------------------
# Temp / scratch
# ------------------------------------------------------------
*.tmp
*.bak
*.orig
scratch/
tmp/

# ------------------------------------------------------------
# Python virtualenv
# ------------------------------------------------------------
venv/
env/
.venv/
.python-version

# ------------------------------------------------------------
# Node (if any MCP server)
# ------------------------------------------------------------
node_modules/
package-lock.json
yarn.lock

# ------------------------------------------------------------
# Docker
# ------------------------------------------------------------
docker-compose.override.yml
.docker/

# ------------------------------------------------------------
# Service runtime configs (have secrets — generated from .example)
# ------------------------------------------------------------
services/searxng/settings.yml
services/langfuse/.env
services/arize_phoenix/.env

# ------------------------------------------------------------
# Obsidian
# ------------------------------------------------------------
.obsidian/workspace*
.obsidian/cache
.obsidian/plugins/*/data.json

# ------------------------------------------------------------
# Jupyter
# ------------------------------------------------------------
.ipynb_checkpoints/
*.ipynb
logs/chainlit*.out

# ------------------------------------------------------------
# Chainlit auto-generated (regenerated on each `chainlit run`)
# ------------------------------------------------------------
.chainlit/translations/
.chainlit/.langgraph_*
.files/
