# Modelfile: tpm-orch
# Custom Qwen3-8B variant for the TPM AI orchestrator
# ref: MASTER_PLAN_v5.md § 3.3 + KV-cache q8_0 trick
#
# Usage:
#   ollama create tpm-orch -f models/orchestrator/Modelfile
#   ollama run tpm-orch
#
# Set TPM_ORCHESTRATOR_MODEL=tpm-orch:latest in .env to make it the default.

FROM qwen3:8b

# 8K context (2x default 4K).
# Empirically measured (May 2026, RTX 5060 8GB):
#   num_ctx 16384 -> 7.2 GB VRAM (only 0.6 GB headroom - too tight for swap)
#   num_ctx 8192  -> ~5.8 GB VRAM (~2 GB headroom - fits scavenger 1.7B swap)
# Synthesizer with 5 snippets x 400 chars + 1500-char answer ~ 3.5K tokens
# total - well within 8K. Bump to 16K only if Vision Worker disabled.
PARAMETER num_ctx 8192

# Note: keep_alive is a request-level option (per /api/chat call), not a
# Modelfile parameter. Set OLLAMA_KEEP_ALIVE=30m as an env var if needed.

# Conservative temperature - we use json_mode often, want low variance.
PARAMETER temperature 0.2

# Repetition penalty for long synthesizer answers.
PARAMETER repeat_penalty 1.1
