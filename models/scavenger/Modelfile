# Modelfile: tpm-scavenger
# Custom Qwen3-1.7B variant for retrieval / cleanup tasks
# ref: MASTER_PLAN_v5.md § 4.2 (Scavenger role)

FROM qwen3:1.7b

# 16K is plenty for retrieval/cleanup tasks; 32K was excessive.
# Scavenger 1.7B at 16K ~ 1.4 GB VRAM (cheap to keep loaded with orchestrator).
PARAMETER num_ctx 16384

# Note: keep_alive is request-level, not a Modelfile parameter. Set
# OLLAMA_KEEP_ALIVE=60m as env var if needed.

# Even lower temperature - retrieval should be deterministic.
PARAMETER temperature 0.0
